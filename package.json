{
  "name": "djoo",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "desktop": "electron .",
    "preview": "vite preview --host 127.0.0.1",
    "dist": "npm run build && electron-builder --win nsis portable"
  },
  "build": {
    "appId": "com.djoo.app",
    "productName": "Djoo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Djoo-0.7-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Djoo-0.7-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "node-id3": "^0.2.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
